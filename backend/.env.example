FRONTEND_ORIGIN=http://localhost:3000,https://your-vercel-app.vercel.app

# --- Saxo OpenAPI SIM (Sprint 2) ---
SAXO_OPENAPI_BASE_URL=https://gateway.saxobank.com/sim/openapi
# Optioneel: statisch access token (verloopt snel); liever refresh flow hieronder.
SAXO_ACCESS_TOKEN=
SAXO_APP_KEY=
SAXO_APP_SECRET=
SAXO_REFRESH_TOKEN=
# Optioneel: pad naar bestand met refresh token (lokaal); wordt bij refresh overschreven.
SAXO_REFRESH_TOKEN_FILE=
# Verplicht bij refresh_token grant (zelfde URL als in Saxo app + Vercel callback).
SAXO_REDIRECT_URI=https://jouw-app.vercel.app/auth/saxo/callback
SAXO_TOKEN_URL=https://sim.logonvalidation.net/token
SAXO_OAUTH_GRANT_TYPE=client_credentials
SAXO_OAUTH_SCOPE=
# Standaard: ingelogde gebruiker / SIM (geen ClientKey nodig).
SAXO_BALANCES_PATH=/port/v1/balances/me
SAXO_POSITIONS_PATH=/port/v1/positions/me
SAXO_NETPOSITIONS_PATH=/port/v1/netpositions/me
SAXO_NETPOSITIONS_TOP=200
SAXO_NDQ_HARD_LIMIT=50
SAXO_CLIENT_KEY=
SAXO_ACCOUNT_KEY=
SAXO_TIMEOUT_SECONDS=12
BOND_COLLATERAL_LTV90=12280000

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
